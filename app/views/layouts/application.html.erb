<!DOCTYPE html>
<html>
  <head>
    <title>Beerkeeper</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <%= favicon_link_tag('favicon.ico') %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header class="bg-light">
      <nav class="navbar navbar-expand-lg">
        <div class="container-xxl">
          <%= link_to root_path, class: 'navbar-brand' do %>
            <%= image_tag "logo.svg", width: '180' %>
          <% end %>
          <div id="navbarSupportedContent">
            <ul class="navbar-nav d-flex gap-2 w-auto">
              <% if current_user %>
                <li class="nav-item">
                  <%= link_to 'ログアウト', session_path(current_user), data: { turbo_method: :delete }, class: 'btn btn-outline-secondary w-100 text-nowrap' %>
                </li>
              <% else %>
                <li class="nav-item">
                  <%= link_to 'ログイン', login_path, class: 'btn btn-outline-secondary w-100 text-nowrap' %>
                </li>
                <li class="nav-item">
                  <%= link_to 'サインアップ', signup_path, class: 'btn btn-primary w-100 text-nowrap' %>
                </li>
              <% end %>
              </li>
            </ul>
          </div>
        </div>
      </nav>
    </header>

    <div class="container">
      <main class="py-5">
        <% flash.each do |message_type, message| %>
          <%= render(AlertComponent.new(message_type: message_type, message: message) ) %>
        <% end %>
        <%= yield %>
      </main>
    </div>
  </body>
</html>
